# =============================================================================
# .env.example — netdirect AI agents
# =============================================================================
# Zkopíruj jako .env a vyplň. Tento soubor JE v gitu. .env NENÍ.
# Na Railway: nastav jako Environment Variables.
# =============================================================================

# Anthropic
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Byte — Jira
# Jak získat: přihlas se jako agent+byte@netdirect.cz →
#   Jira → Profile → Manage account → Security → API tokens → Create
# Platnost: 1 rok — zapiš datum do agents.config.yaml → byte.jira.token_expires
BYTE_JIRA_API_TOKEN=ATATT3x_CHANGE_ME

# Byte — Bitbucket OAuth2
# Jak získat: BB → Settings → OAuth consumers → Add consumer
#   Callback URL: https://byte-agent.up.railway.app/oauth/callback
#   Permissions: Repositories (read/write), Pull requests (read/write)
BYTE_BB_OAUTH_CLIENT_ID=CHANGE_ME
BYTE_BB_OAUTH_CLIENT_SECRET=CHANGE_ME

# Webhook security
# Generuj: python -c "import secrets; print(secrets.token_hex(32))"
BYTE_RAILWAY_URL=https://byte-agent.up.railway.app
FORGE_SHARED_SECRET=CHANGE_ME_random_hex

# Atlas (zatím prázdné — vyplnit až bude účet)
ATLAS_JIRA_API_TOKEN=

# Lucy (zatím prázdné)
LUCY_JIRA_API_TOKEN=
LUCY_TEAMS_CLIENT_SECRET=
